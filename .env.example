# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (e.g. for OAuth redirects)
APP_URL="MY_APP_URL"

# Google OAuth Credentials (for YouTube Data API)
GOOGLE_OAUTH_CLIENT_ID="MY_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="MY_CLIENT_SECRET"
